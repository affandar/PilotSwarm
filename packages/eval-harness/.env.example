# pilotswarm-eval-harness — environment template
#
# Vitest auto-loads `.env` from the monorepo root via vitest.config.ts.
# Copy the repo-root `.env.example` to `.env` and fill these in. The
# eval-harness reads them at run time; no manual `env $(grep …)` shim
# is required.

# --- Required for any LIVE-gated suite (LIVE=1) ----------------------

# PostgreSQL — LiveDriver / DurabilityDriver provision isolated CMS
# schemas per sample. Must be reachable, must allow CREATE SCHEMA.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pilotswarm

# GitHub token with Copilot access. PilotSwarm's
# ModelProviderRegistry resolves `env:GITHUB_TOKEN` from the default
# providers fixture (`packages/sdk/test/fixtures/model-providers.test.json`),
# so this single credential drives every model used by LiveDriver and
# the LLM-as-judge path.
GITHUB_TOKEN=ghp_xxx

# --- LLM-as-judge (LIVE=1 LIVE_JUDGE=1) ------------------------------

# Defaults to the SDK test fixture (which uses GITHUB_TOKEN). Override
# only if you maintain a separate providers manifest.
# PS_MODEL_PROVIDERS_PATH=/abs/path/to/.model_providers.json

# Optional: skip PilotSwarmJudgeClient entirely and call OpenAI direct.
# Takes precedence over the GITHUB_TOKEN path when set.
# OPENAI_API_KEY=sk-…
# OPENAI_BASE_URL=https://api.openai.com/v1

# Judge model overrides (pair-wise A/B tests in llm-judge-live).
# PilotSwarm path defaults: github-copilot:gpt-4.1, github-copilot:claude-sonnet-4.6
# OpenAI path defaults:     gpt-4o-mini, gpt-4o
# LIVE_JUDGE_MODEL_A=
# LIVE_JUDGE_MODEL_B=

# --- Performance gating ---------------------------------------------

# Heavy concurrency profiler. PERF_HEAVY_N8 raises the parallel
# session count from 7 to 15 — DB connection heavy.
# PERF_HEAVY=1
# PERF_HEAVY_N8=1
# PERF_HEAVY_MAX_CONNECTIONS=60

# Durability perf suite. Most cases assert deferred state until the
# SDK emits matching `*-start` events.
# PERF_DURABILITY=1

# Promotes DB-budget skips into hard assertions. Requires the
# `pg_stat_statements` extension actually loaded in Postgres
# (shared_preload_libraries + CREATE EXTENSION pg_stat_statements).
# PG_STAT_STATEMENTS_ENABLED=1

# --- Reports ---------------------------------------------------------

# Auto-wires JsonlReporter; one `<runId>.jsonl` per task plus per-fail
# detail files. Already gitignored under packages/eval-harness/.gitignore.
# EVAL_REPORTS_DIR=.eval-results
#
# After the run, generate a consolidated Markdown report from the jsonl
# files via `node bin/report.mjs [<dir>]` or `bin/run-live.sh --report`.
# Output lands at <dir>/REPORT-<ts>.md and works on partial / in-flight
# runs (re-run to refresh).

# --- Debug / teardown knobs -----------------------------------------

# EVAL_VERBOSE_TEARDOWN=1     # surface afterAll cleanup stderr
# KEEP_DURABILITY_ENV=1       # leave durability test env on disk
# DUROXIDE_LOG_LEVEL=error    # rust-side worker log filter
# REFRESH_GOLDEN=1            # regenerate golden snapshots in regression-live
# PROMPT_TESTING=1            # gate prompt-testing-live (along with LIVE=1)
