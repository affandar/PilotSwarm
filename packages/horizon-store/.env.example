# Connection to a HorizonDB instance (preview) with pg_textsearch, AI pipelines,
# AGE, and pg_durable enabled. PoCs read this; nothing here touches a PilotSwarm DB.
HORIZON_DATABASE_URL=postgresql://user:pass@localhost:5432/horizon_facts_poc

# Embedding endpoint used by the AI-pipeline / semantic tests. Placeholder values
# only. Point these at an OpenAI/Azure-OpenAI-compatible embeddings endpoint.
# For Azure AI Foundry / Azure OpenAI, HORIZON_EMBED_URL is the full embeddings
# POST URL (deployment in the path + api-version) and HORIZON_EMBED_MODEL is the
# deployment name (sent as the request-body "model").
#
# NOTE: the in-DB df.http() pipeline enforces an Azure egress allow-list. The
# Foundry "unified" host *.services.ai.azure.com is BLOCKED in-DB; the setup code
# auto-rewrites it to the classic *.openai.azure.com host (same deployment), which
# is allowed. The Node fallback (embedPending) works with either host.
HORIZON_EMBED_URL=https://<resource>.services.ai.azure.com/openai/deployments/<deployment>/embeddings?api-version=2024-02-01
HORIZON_EMBED_MODEL=text-embedding-3-small
HORIZON_EMBED_DIM=1536
HORIZON_EMBED_API_KEY=<EMBED_KEY>
HORIZON_EMBED_API_KEY_HEADER=api-key
