# GitHub token for Copilot API access (fallback, not needed with custom LLM)
# Use: gh auth token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Microsoft AI Foundry Model deployment keys
AZURE_FW_GLM5_KEY=your-azure-fw-glm5-key
AZURE_KIMI_K25_KEY=your-azure-kimi-k25-key
AZURE_OAI_KEY=your-azure-openai-key

# Anthropic API key (direct API access for Claude models)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Model selection is managed by model_providers.json
# Override with COPILOT_MODEL env var only if needed.

# Duroxide PostgreSQL store (local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/durable_copilot

# Optional PostgreSQL / runtime scaling knobs (env-only configuration)
# DUROXIDE_PG_POOL_MAX=10
# PILOTSWARM_CMS_PG_POOL_MAX=3
# PILOTSWARM_FACTS_PG_POOL_MAX=3
# PILOTSWARM_ORCHESTRATION_CONCURRENCY=2
# PILOTSWARM_WORKER_CONCURRENCY=2

# ── EnhancedFactStore + Knowledge Graph (optional, HorizonDB) ────────────────
# The default facts store is plain Postgres (PgFactStore). To light up
# multi-signal search (lexical + semantic + hybrid) and the durable in-DB
# embedder, point PilotSwarm at a HorizonDB (preview) cluster that has
# pgvector + pg_textsearch + pg_durable enabled. The knowledge graph is a
# SEPARATE, opt-in provider needing Apache AGE.
#
# The shipped PilotSwarm worker entrypoints (CLI/portal embedded worker and the
# standalone K8s worker) auto-wire these via the SDK helper `horizonConfigFromEnv()`,
# which maps them to the worker config below. Custom SDK apps can call the same
# helper (or set the fields directly). See the worked example in
# docs/configuration.md#enhanced-facts--knowledge-graph-optional:
#   HORIZON_DATABASE_URL       -> worker.enhancedFactsDatabaseUrl (provider inferred "horizon")
#   HORIZON_FACTS_SCHEMA       -> worker.enhancedFactsSchema (default "horizon_facts")
#   HORIZON_GRAPH_DATABASE_URL -> worker.graphDatabaseUrl (opt-in; unset ⇒ no graph tools)
#   HORIZON_GRAPH_SCHEMA       -> worker.graphSchema (default "horizon_graph")
#   HORIZON_EMBED_*            -> worker.horizonEmbed (durable embedder endpoint)
# They also gate the @pilotswarm/horizon-store provider tests and the SDK's
# HDB-gated composition test (both skip when unset). See docs/configuration.md
# and docs/facts-table.md.
#
# Enhanced facts store target (pgvector / pg_textsearch / pg_durable). Setting
# this alone makes the worker construct the enhanced provider instead of
# PgFactStore (provider inferred as "horizon"; override with factsProvider).
#
# HorizonDB TLS: a bare `?sslmode=require` is all you need — the provider
# normalizes HorizonDB TLS the same way PilotSwarm handles DATABASE_URL (it
# encrypts without verifying the preview cluster's self-signed CA), so you do
# NOT have to hand-append `uselibpqcompat=true`. (Raw `psql`/`pg` clients that
# bypass the provider still want that flag; the provider accepts it either way.)
# HORIZON_DATABASE_URL=postgresql://user:pass@<cluster>.postgres.database.azure.com:5432/horizon?sslmode=require
#
# Optional SEPARATE knowledge-graph (Apache AGE) target. Unset ⇒ no graph, no
# graph tools (never selected implicitly). May be the SAME URL as
# HORIZON_DATABASE_URL (one HorizonDB); if so, the graph schema MUST differ from
# the facts schema (default graph schema is "horizon_graph"), or the worker
# fails fast on a schema collision. Same TLS handling as above.
# HORIZON_GRAPH_DATABASE_URL=postgresql://user:pass@<cluster>.postgres.database.azure.com:5432/horizon?sslmode=require
#
# Embedding endpoint for the in-DB durable embedder (OpenAI/Azure-OpenAI shape).
# Omit to run enhanced search in lexical-only mode (semantic returns nothing for
# un-embedded facts; hybrid degrades to lexical).
# HORIZON_EMBED_URL is the full embeddings POST URL (deployment in path + api-version);
# HORIZON_EMBED_MODEL is the deployment name sent as the request-body "model";
# HORIZON_EMBED_DIM MUST equal the vector(N) column dimension.
# NOTE: in-DB df.http() blocks the Foundry *.services.ai.azure.com host; the
# provider auto-rewrites it to the classic *.openai.azure.com host (same deployment).
# HORIZON_EMBED_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>/embeddings?api-version=2024-02-01
# HORIZON_EMBED_MODEL=text-embedding-3-small
# HORIZON_EMBED_DIM=1536
# HORIZON_EMBED_API_KEY=<embed-key>           # ⚠ stored in a durable var (plaintext at rest) — incubation TODO
# HORIZON_EMBED_API_KEY_HEADER=api-key        # "Authorization" for OpenAI-style endpoints
# HORIZON_EMBED_BEARER=false                  # send "Bearer <key>"; inferred true when the header is "Authorization"

# Azure Blob Storage for session dehydration/hydration
# Disabled for local runs so PilotSwarm uses filesystem session/artifact stores.
# Re-enable or use .env.remote for blob-backed remote runs.
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=copilot-sessions

# Entra ID auth for the web portal (optional — omit to disable auth)
# Register an app in Azure AD / Entra ID and add the portal URL as a SPA redirect URI.
PORTAL_AUTH_PROVIDER=entra
PORTAL_AUTH_ENTRA_TENANT_ID=<your-entra-tenant-id>
PORTAL_AUTH_ENTRA_CLIENT_ID=<your-entra-client-id>

# Optional portal authz email allowlists.
# Use normalized user email addresses.
# If omitted, any successfully authenticated user is allowed in.
# PORTAL_AUTHZ_ADMIN_GROUPS=admin1@contoso.com,admin2@contoso.com
# PORTAL_AUTHZ_USER_GROUPS=user1@contoso.com,user2@contoso.com
