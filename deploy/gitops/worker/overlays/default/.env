# Overlay values rewritten by the deploy pipeline (substitute-env.mjs)
# from the env Map at rollout time. Keys MUST appear here for the
# substituter to target them; placeholder values are overwritten.
#
# Three categories of values live in this ConfigMap:
#   1. Kustomize replacement sources (IMAGE, NAMESPACE, KV_NAME,
#      WORKLOAD_IDENTITY_CLIENT_ID, AZURE_TENANT_ID) — used by the
#      replacements: block in kustomization.yaml; not consumed by the
#      worker runtime but harmless when projected via envFrom.
#   2. Worker app config that is NOT a secret (LLM_ENDPOINT,
#      LLM_PROVIDER_TYPE, LLM_API_VERSION, AZURE_STORAGE_CONTAINER) —
#      formerly stored in Key Vault; now plain config so they don't
#      occupy a secret slot.
#   3. Future MI feature-switch toggles (PILOTSWARM_USE_MANAGED_IDENTITY,
#      AZURE_STORAGE_ACCOUNT_URL) wire here when MI mode lands.
IMAGE=placeholder.azurecr.io/pilotswarm-worker:placeholder
NAMESPACE=pilotswarm
KV_NAME=placeholder
WORKLOAD_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# Custom LLM endpoint settings (LLM_ENDPOINT / LLM_PROVIDER_TYPE /
# LLM_API_VERSION) are intentionally NOT projected here. The default
# bicep-deploy path uses the GitHub Copilot SDK + the model providers
# catalog — no custom-endpoint env vars required. Stamps that want a
# custom Azure OpenAI / Anthropic-direct endpoint can add a stamp-local
# kustomize patch that adds them to the worker-env ConfigMap.
AZURE_STORAGE_CONTAINER=copilot-sessions
# Storage managed-identity flag + account URL (consumed by
# packages/sdk/src/blob-store.ts → createSessionBlobStore). Setting the
# flag to "1" tells the worker to use DefaultAzureCredential (federated
# CSI UAMI) instead of a connection-string shared key. The account URL
# is composed by deploy.mjs from BLOB_CONTAINER_ENDPOINT (BaseInfra
# output). The legacy `scripts/deploy-aks.sh` path leaves the flag
# unset and continues to work via AZURE_STORAGE_CONNECTION_STRING.
PILOTSWARM_USE_MANAGED_IDENTITY=1
AZURE_STORAGE_ACCOUNT_URL=https://placeholder.blob.core.windows.net/
# CMS + facts pools authenticate via AAD token (pg-pool factory, see
# packages/sdk/src/pg-pool-factory.ts). The URL is passwordless; the
# `user@` segment must match the AAD principal registered as a Postgres
# administrator (postgres.bicep `aadAdminPrincipalName`). Composed by
# deploy.mjs from POSTGRES_FQDN + POSTGRES_AAD_ADMIN_PRINCIPAL_NAME.
PILOTSWARM_CMS_FACTS_DATABASE_URL=postgresql://placeholder@placeholder:5432/placeholder?sslmode=require
PILOTSWARM_DB_AAD_USER=placeholder
# DATABASE_URL is config (not a KV secret) in the bicep-deploy flow. The
# substituter composes it at deploy time from POSTGRES_FQDN + the bootstrap
# admin password (deploy/services/base-infra/bicep/postgres.bicep). Kept
# available for the legacy deploy-aks.sh flow and as a fallback when MI
# is not enabled. In MI mode the duroxide orchestration store ignores
# any embedded password and authenticates via duroxide-node's native
# Entra path; CMS + facts use PILOTSWARM_CMS_FACTS_DATABASE_URL above.
DATABASE_URL=postgresql://placeholder:placeholder@placeholder:5432/placeholder?sslmode=require
# SPC keys hash. Computed by deploy/scripts/lib/spc-keys-hash.mjs from
# the worker SPC's projected key list. Read by the worker-replacements
# kustomize component and stamped into the Deployment pod-template
# annotation `pilotswarm.dev/spc-keys-hash`. See spc-keys-hash.mjs for
# rationale. Placeholder value is overwritten by substitute-env.mjs.
SPC_KEYS_HASH=placeholder
# User OBO Propagation. Un-versioned AKV key URL for the OBO KEK
# provisioned by base-infra/keyvault.bicep when OBO_ENABLED=true. The
# worker's `AkvEnvelopeCrypto` (packages/sdk/src/envelope-crypto.ts) reads
# this at startup to unwrap per-RPC user access tokens. Emits __PS_UNSET__
# when OBO_ENABLED=false; the worker runtime strips sentinel values at
# startup and `selectEnvelopeCrypto` returns null — the principal-only
# envelope path engages (FR-002 backwards-compat).
OBO_KEK_KID=__PS_UNSET__
# Downstream OBO scope. Worker's `selectEnvelopeCrypto`
# (packages/sdk/src/envelope-crypto.ts) requires this to be set in order
# to engage the AKV backend; without it, the worker treats incoming
# envelopes as principal-only (no token decrypt path). Mirrored from the
# portal overlay so the portal-encrypted ciphertext can be unwrapped here.
# Stays unset (__PS_UNSET__ stripped at startup) when OBO_ENABLED=false.
PORTAL_AUTH_ENTRA_DOWNSTREAM_SCOPE=__PS_UNSET__
# OBO live-smoke harness (opt-in). When `PLUGIN_DIRS` resolves to the
# in-image smoke plugin directory, the worker entrypoint loads the
# `obo_smoke_*` tools (packages/obo-smoke-plugin/). The smoke plugin
# reads OBO_SMOKE_* on every handler call, so a stamp can opt in by
# setting these in `deploy/envs/local/<env>/.env`. Default stamps leave
# them as `__PS_UNSET__` — substitute-env passes the sentinel through
# unchanged, the worker runtime strips `__PS_UNSET__` values at startup,
# and the smoke plugin stays inert. The `compose-env.test.mjs`
# invariant forbids `deploy/scripts/lib/` from referencing `OBO_SMOKE_*`
# string literals, which is why these are listed in the gitops overlay
# (not in lib/) and resolved through the generic substitute-env
# `__PS_UNSET__` passthrough.
OBO_SMOKE_ENABLED=__PS_UNSET__
OBO_SMOKE_WORKER_APP_TENANT_ID=__PS_UNSET__
OBO_SMOKE_WORKER_APP_CLIENT_ID=__PS_UNSET__
OBO_SMOKE_WORKER_APP_GRAPH_SCOPE=__PS_UNSET__
OBO_SMOKE_WORKER_APP_CLIENT_SECRET=__PS_UNSET__
OBO_SMOKE_TEST_USER_UPN=__PS_UNSET__
PLUGIN_DIRS=__PS_UNSET__
