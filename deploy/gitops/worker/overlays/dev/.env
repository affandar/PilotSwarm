# Overlay values merged over base's placeholder defaults.
# EV2 renders this file from ServiceGroupRoot scope bindings at rollout
# (Phase 5 GenerateEnvForEv2.sh). Committed contents are comments only
# — no environment-specific literals land in git (FR-009). Each EV2
# rollout replaces this file with real key=value pairs, e.g.:
#   IMAGE=<acr>/<image-name>:<tag>
#   IMAGE_TAG=20250101.1
#   ACR_LOGIN_SERVER=<region>.azurecr.io
#   ACR_NAME=<acr>
#   KV_NAME=<kv>
#   WORKLOAD_IDENTITY_CLIENT_ID=<uuid>
#   AZURE_TENANT_ID=<tenant-uuid>
