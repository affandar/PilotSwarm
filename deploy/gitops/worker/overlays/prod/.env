# Overlay values substituted by EV2 DeployApplicationManifest.sh +
# GenerateEnvForEv2.ps1 at rollout time. The committed placeholder
# values are generic/non-environment-specific (FR-009) — EV2 replaces
# them from deploy/ev2/Common/Parameters/DeployApplicationManifest.parameters.json
# (after scope-binding token rewriting). Keys MUST appear here for the
# substituter to target them.
IMAGE=placeholder.azurecr.io/pilotswarm-worker:placeholder
IMAGE_TAG=placeholder
IMAGE_NAME=pilotswarm-worker
ACR_LOGIN_SERVER=placeholder.azurecr.io
ACR_NAME=placeholder
NAMESPACE=copilot-runtime
KV_NAME=placeholder
WORKLOAD_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
