# Overlay values substituted by EV2 DeployApplicationManifest.sh +
# GenerateEnvForEv2.ps1 at rollout time. Committed placeholder values
# are generic/non-environment-specific (FR-009) — EV2 replaces them
# from deploy/ev2/Common/Parameters/DeployApplicationManifest.parameters.json
# (after scope-binding token rewriting). Keys MUST appear here for the
# substituter to target them.
IMAGE=placeholder.azurecr.io/pilotswarm-portal:placeholder
IMAGE_TAG=placeholder
IMAGE_NAME=pilotswarm-portal
ACR_LOGIN_SERVER=placeholder.azurecr.io
ACR_NAME=placeholder
NAMESPACE=pilotswarm-portal
KV_NAME=placeholder
WORKLOAD_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
PORTAL_HOSTNAME=placeholder.example.com
