# Overlay values rewritten by the deploy pipeline (substitute-env.mjs)
# from the env Map at rollout time. Keys MUST appear here for the
# substituter to target them; placeholder values are overwritten.
IMAGE=placeholder.azurecr.io/pilotswarm-portal:placeholder
NAMESPACE=pilotswarm
KV_NAME=placeholder
WORKLOAD_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
PORTAL_HOSTNAME=placeholder.example.com
# Storage managed-identity flag + account URL (mirrors worker overlay).
# The portal currently does not read storage directly, but the flag is
# kept here for parity in case future portal features stream artifacts.
PILOTSWARM_USE_MANAGED_IDENTITY=1
AZURE_STORAGE_ACCOUNT_URL=https://placeholder.blob.core.windows.net/
# CMS + facts pools authenticate via AAD token. Composed by deploy.mjs
# from POSTGRES_FQDN + POSTGRES_AAD_ADMIN_PRINCIPAL_NAME.
PILOTSWARM_CMS_FACTS_DATABASE_URL=postgresql://placeholder@placeholder:5432/placeholder?sslmode=require
PILOTSWARM_DB_AAD_USER=placeholder
# DATABASE_URL is the password URL kept available for the legacy
# deploy-aks.sh flow and as a fallback when MI is not enabled. In MI
# mode the duroxide store ignores any embedded password and
# authenticates via duroxide-node's native Entra path; CMS + facts use
# the PILOTSWARM_CMS_FACTS_DATABASE_URL above.
DATABASE_URL=postgresql://placeholder:placeholder@placeholder:5432/placeholder?sslmode=require

# SPC keys hash. Computed by deploy/scripts/lib/spc-keys-hash.mjs from
# the portal SPC's projected key list. Read by the portal-replacements
# kustomize component and stamped into the Deployment pod-template
# annotation `pilotswarm.dev/spc-keys-hash`. See spc-keys-hash.mjs for
# rationale. Placeholder value is overwritten by substitute-env.mjs.
SPC_KEYS_HASH=placeholder
# Portal auth/authz config (non-credentials). Mirrored from
# deploy/scripts/lib/portal-config.mjs. Empty values get rendered as the
# __PS_UNSET__ sentinel so substitute-env's fail-closed gate is satisfied;
# the portal runtime strips the sentinel from process.env at startup.
PORTAL_AUTH_PROVIDER=__PS_UNSET__
PORTAL_AUTH_ENTRA_TENANT_ID=__PS_UNSET__
PORTAL_AUTH_ENTRA_CLIENT_ID=__PS_UNSET__
PORTAL_AUTH_ALLOW_UNAUTHENTICATED=__PS_UNSET__
PORTAL_AUTH_ENTRA_ADMIN_GROUPS=__PS_UNSET__
PORTAL_AUTH_ENTRA_USER_GROUPS=__PS_UNSET__
PORTAL_AUTHZ_DEFAULT_ROLE=__PS_UNSET__
PORTAL_AUTHZ_ADMIN_GROUPS=__PS_UNSET__
PORTAL_AUTHZ_USER_GROUPS=__PS_UNSET__
# User OBO Propagation (Phase 6).
#   PORTAL_AUTH_ENTRA_DOWNSTREAM_SCOPE — user-supplied via deploy/envs/local/<env>/.env
#     (typical: `api://<worker-app>/.default`). __PS_UNSET__ when not set.
#   OBO_KEK_KID — populated from base-infra `oboKekKid` bicep output via OUTPUT_ALIAS
#     (substitute-env). Emits __PS_UNSET__ when OBO_ENABLED=false. The portal runtime
#     strips sentinel values at startup, so the app sees the key as truly unset and
#     the existing principal-only envelope path engages (FR-002 backwards-compat).
PORTAL_AUTH_ENTRA_DOWNSTREAM_SCOPE=__PS_UNSET__
OBO_KEK_KID=__PS_UNSET__
