# Overlay values rewritten by the deploy pipeline (substitute-env.mjs)
# from the env Map at rollout time. Keys MUST appear here for the
# substituter to target them; placeholder values are overwritten.
IMAGE=placeholder.azurecr.io/pilotswarm-portal:placeholder
NAMESPACE=pilotswarm
KV_NAME=placeholder
WORKLOAD_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
PORTAL_HOSTNAME=placeholder.example.com
# Storage managed-identity flag + account URL (mirrors worker overlay).
# The portal currently does not read storage directly, but the flag is
# kept here for parity in case future portal features stream artifacts.
PILOTSWARM_USE_MANAGED_IDENTITY=1
AZURE_STORAGE_ACCOUNT_URL=https://placeholder.blob.core.windows.net/
# CMS + facts pools authenticate via AAD token. Composed by deploy.mjs
# from POSTGRES_FQDN + POSTGRES_AAD_ADMIN_PRINCIPAL_NAME.
PILOTSWARM_CMS_FACTS_DATABASE_URL=postgresql://placeholder@placeholder:5432/placeholder?sslmode=require
PILOTSWARM_DB_AAD_USER=placeholder
# DATABASE_URL is the password URL used by duroxide's PostgresProvider
# (no AAD token-callback hook upstream). CMS + facts use the
# PILOTSWARM_CMS_FACTS_DATABASE_URL above.
DATABASE_URL=postgresql://placeholder:placeholder@placeholder:5432/placeholder?sslmode=require

# SPC keys hash. Computed by deploy/scripts/lib/spc-keys-hash.mjs from
# the portal SPC's projected key list. Read by the portal-replacements
# kustomize component and stamped into the Deployment pod-template
# annotation `pilotswarm.dev/spc-keys-hash`. See spc-keys-hash.mjs for
# rationale. Placeholder value is overwritten by substitute-env.mjs.
SPC_KEYS_HASH=placeholder