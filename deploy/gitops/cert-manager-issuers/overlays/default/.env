# Overlay values for the cert-manager-issuers Kustomization. Rewritten
# by deploy.mjs / substitute-env.mjs from the env map at rollout time.
#
# ACME_EMAIL — registered with Let's Encrypt for expiry notifications and
#              account recovery. Per-stamp value (the operator running
#              the deploy supplies it via `--acme-email` to new-env.mjs
#              or by editing deploy/envs/local/<name>/env directly).
# INGRESS_CLASS — must match the AGIC controller's IngressClass on the
#                 stamp. AGIC publishes class `azure-application-gateway`
#                 by default; if a stamp configures a non-default class
#                 the overlay env can override.
ACME_EMAIL=placeholder@example.com
INGRESS_CLASS=azure-application-gateway
