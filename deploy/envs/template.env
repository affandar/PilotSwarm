# Template for OSS Node deploy orchestrator local env files.
#
# This file is the source the scaffolder (deploy/scripts/new-env.mjs) copies
# from when creating a personal env at deploy/envs/local/<name>/env. Local
# files are STANDALONE — there is no runtime cascade onto this template.
# That means edits to this template only affect newly-scaffolded envs, not
# existing ones (an existing local env is a complete frozen record of its
# original deployment target).
#
# What lives here:
#   • Generic static defaults safe for any stamp (region, namespace, WAF
#     mode, ACR SKU, edge mode, TLS source, MS tenant, etc.)
#   • Empty placeholders for deployment-target keys — the scaffolder
#     substitutes per-stamp values during `npm run deploy:new-env`.
#
# What does NOT live here (computed by Bicep / cascaded at runtime via the
# FR-022 alias map): ACR/AKS/KV names, storage endpoints, workload-identity
# clientId, approver UAMI id, Front Door identifiers, etc. Resource *names*
# are derived inside Bicep from RESOURCE_PREFIX (e.g. `${alphaPrefix}sa${unique6}`,
# `${prefix}-aks`); we do not pre-compute them here.

# ─── Subscription & deployment targets (scaffolder fills these in) ───
SUBSCRIPTION_ID=
LOCATION=westus3

# RESOURCE_PREFIX is the Bicep `resourceNamePrefix` input — uniquely names
# every Azure resource in BaseInfra/Worker/Portal templates. Scaffolder
# pattern: ps<envname>.
RESOURCE_PREFIX=

# Per-region RG that BaseInfra/Worker/Portal deploy into.
# Scaffolder pattern: ${RESOURCE_PREFIX}-${regionShort}-rg.
RESOURCE_GROUP=

# GlobalInfra deployment target (subscription-scope deployment lands an RG of
# this name and provisions Front Door + DNS into it).
# Scaffolder pattern: ${RESOURCE_PREFIX}global.
GLOBAL_RESOURCE_PREFIX=
GLOBAL_RESOURCE_GROUP=

# Portal logical resource name (Portal Bicep `resourceName` param).
# Scaffolder pattern: ${RESOURCE_PREFIX}-${regionShort}-portal.
PORTAL_RESOURCE_NAME=

# Worker pod namespace inside the AKS cluster.
NAMESPACE=pilotswarm

# ─── Bicep input parameters (static) ───
# SSL_CERT_DOMAIN_SUFFIX is only consumed by the enterprise path
# (cert subject = `${resourceName}.${SSL_CERT_DOMAIN_SUFFIX}`); OSS deploys
# leave it empty and bicep derives the cert subject from the AppGw's Azure
# DNS label instead.
SSL_CERT_DOMAIN_SUFFIX=
WAF_MODE=Prevention
ACR_SKU=Basic
APP_GATEWAY_PRIVATE_IP=10.20.16.10

# ─── Observability ───
# Log Analytics workspace retention (days) for AKS Container Insights
# (ContainerLogV2). 30 is included free; longer is billed at the
# workspace's PerGB2018 rate.
LOG_ANALYTICS_RETENTION_DAYS=30

# Optional path (relative to repo root or absolute) to a JSON file containing
# an array of AFD WAF custom rules merged into properties.customRules.rules at
# deploy time. Recommended location: `deploy/envs/local/<env>/waf-custom-rules.json`
# (the entire `deploy/envs/local/` tree is gitignored, so site-specific rules
# such as corpnet allow-lists never get checked in). Leave unset to deploy
# with no custom rules. Example contents:
#   [
#     { "name": "AllowServiceTagRule", "enabledState": "Enabled", "priority": 100,
#       "ruleType": "MatchRule", "action": "Block",
#       "matchConditions": [{
#         "matchVariable": "SocketAddr", "operator": "ServiceTagMatch",
#         "negateCondition": true, "matchValue": ["CorpNetPublic", "CorpNetSAW"]
#       }] }
#   ]
WAF_CUSTOM_RULES_FILE=

# ─── Edge / public-ingress topology ───
# Two modes:
#   afd     — Azure Front Door + Private Link → AppGw private listener.
#             AFD endpoint at `*.z01.azurefd.net` is the user-facing URL.
#             Requires a publicly-trusted cert (Azure rejects self-signed
#             PL origins with `EnforceCertificateNameCheck must be enabled
#             for Private Link`). For OSS, the cert subject is the AppGw's
#             `<name>.<region>.cloudapp.azure.com` Azure DNS label and LE
#             issues via cert-manager (TLS_SOURCE=letsencrypt) — zero DNS
#             prerequisite. For enterprise the subject is
#             `${resourceName}.${SSL_CERT_DOMAIN_SUFFIX}` and the cert
#             comes from an AKV-registered issuer (TLS_SOURCE=akv).
#   private — AppGw private-IP listener only, no AFD. Caller manages DNS
#             (private DNS zone, hosts file, or VPN-resolvable record) to
#             APP_GATEWAY_PRIVATE_IP. Both cert sources work; LE in this
#             mode requires DNS-01 (an Azure DNS zone the user controls).
EDGE_MODE=afd

# ─── TLS cert source ───
# Two sources:
#   letsencrypt — cert-manager + Let's Encrypt prod (HTTP-01 for afd,
#                 DNS-01 for private). Default for OSS / testing.
#                 Auto-renewing. Requires ACME_EMAIL.
#   akv         — AKV-registered issuer + bicep cert deployment script
#                 (BYO CA). Required for the enterprise path and any closed-network
#                 deployment. Requires PORTAL_TLS_ISSUER_NAME pointing at
#                 a registered issuer (see akv-certificate-issuer.bicep).
# Self-signed is no longer supported on the deploy path. For local
# off-Azure development the in-process portal still uses self-signed.
TLS_SOURCE=letsencrypt

# ACME registration email (Let's Encrypt). LE sends renewal-failure
# notices here. Required when TLS_SOURCE=letsencrypt; ignored for akv.
# Per-stamp value — scaffolder prompts for this so the template doesn't
# leak personal addresses.
ACME_EMAIL=

# ─── Overlay .env-only static keys ───
# Consumed by deploy/gitops/<service>/overlays/<env>/.env via substitute-env.mjs.
# AZURE_TENANT_ID is the Microsoft tenant.
AZURE_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47

# Kubernetes IngressClass that AGIC publishes on the stamp. Consumed by the
# cert-manager-issuers Let's Encrypt ClusterIssuer (HTTP-01 solver) and any
# Ingress object that needs to opt into AGIC. AGIC's default class is
# `azure-application-gateway`; override only if a stamp explicitly configures
# a non-default class on the AGIC controller.
INGRESS_CLASS=azure-application-gateway

# PORTAL_HOSTNAME is intentionally NOT set here. It is a per-stamp value
# derived from the bicep `${resourceName}.${sslCertificateDomainSuffix}`
# formula and surfaced as the Portal bicep `backendHostName` output. The
# `OUTPUT_ALIAS` map in `deploy/scripts/lib/deploy-bicep.mjs` aliases that
# output to `PORTAL_HOSTNAME`, which is then substituted into the Portal
# overlay `.env` (placeholder `__PORTAL_HOSTNAME__`). For workflows that
# run `--steps manifests,rollout` without `bicep`, the value comes from
# the bicep-outputs cache (`deploy/.tmp/<env>/bicep-outputs.cache.json`)
# populated by a prior bicep step. If the cache is empty, run with
# `--steps bicep,manifests,rollout` once so the cache fills.

# ─── Bicep-deploy MI feature switch (Chunks B + C) ───
# Static for the bicep-deploy path. Causes worker to use DefaultAzureCredential
# for blob storage (Chunk B) and AAD token callback for CMS+facts pools
# (Chunk C). Legacy `scripts/deploy-aks.sh` does NOT consume these — its
# own K8s secret keeps the connection-string flow intact.
PILOTSWARM_USE_MANAGED_IDENTITY=1
AZURE_STORAGE_CONTAINER=copilot-sessions

# ─── Azure AI Foundry (optional) ───
# When true, base-infra provisions a Microsoft.CognitiveServices/accounts
# (kind=AIServices) named `${RESOURCE_PREFIX}-aif` and the operator-supplied
# JSON file at FOUNDRY_DEPLOYMENTS_FILE drives N model deployments under it.
# The account's primary key auto-flows into KV as `azure-oai-key`
# (auto-secrets.bicep) and the account's data-plane endpoint flows into
# the worker base catalog as `__FOUNDRY_ENDPOINT__` substitution at
# manifest-staging time. When false, no Foundry account is provisioned and
# the catalog Foundry providers stay unresolved at runtime — the stamp
# falls back to its remaining providers (github-copilot, anthropic).
FOUNDRY_ENABLED=false

# Foundry SKU. S0 is the only generally-available paid SKU for AIServices.
FOUNDRY_SKU=S0

# Path (relative to repo root or absolute) to a JSON array file describing
# the model deployments to create under the Foundry account. Threaded into
# the bicep deploy as `--parameters foundryDeployments=@<file>`. The
# scaffolder writes deploy/envs/local/<env>/foundry-deployments.json when
# FOUNDRY_ENABLED is selected during `npm run deploy:new-env`. The entire
# `deploy/envs/local/` tree is gitignored, so the file is per-stamp and
# never checked in. Required when FOUNDRY_ENABLED=true; ignored otherwise.
FOUNDRY_DEPLOYMENTS_FILE=
