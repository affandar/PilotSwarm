# Single-stage: install from npm (linux binary published to registry)
# trixie-slim (Debian 13, glibc 2.41) required by duroxide-linux-x64-gnu >= 0.1.25
# (prebuilds link against GLIBC_2.39; bookworm-slim is 2.36 and crashes at dlopen).
FROM node:24-trixie-slim

# Install CA certificates for HTTPS
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy workspace root and package manifests
COPY package.json package-lock.json ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/app/package.json ./packages/app/
# horizon-store package.json must be present BEFORE `npm ci` so npm creates the
# node_modules/@pilotswarm/horizon-store workspace symlink the SDK's dynamic
# import("@pilotswarm/horizon-store") resolves at runtime (optional EnhancedFactStore).
COPY packages/horizon-store/package.json ./packages/horizon-store/
COPY scripts/postinstall.js ./scripts/
# `npm ci` enforces the committed package-lock.json so worker image rebuilds
# from this SHA are byte-reproducible. Matches deploy/Dockerfile.starter.
RUN npm ci --omit=dev --force

# Copy built SDK dist + bundled plugins, worker script, and app plugins
COPY packages/sdk/dist/ ./packages/sdk/dist/
COPY packages/sdk/plugins/ ./packages/sdk/plugins/
COPY packages/sdk/examples/worker.js ./packages/sdk/examples/
COPY packages/app/tui/plugins/ ./packages/app/tui/plugins/

# api-client (plain ESM) — the SDK's dist/web/api-connection.js imports it at
# load time, so it must be present even though workers use direct { store } mode.
COPY packages/sdk/api/index.js packages/sdk/api/index.d.ts ./packages/sdk/api/
COPY packages/sdk/api/src/ ./packages/sdk/api/src/

# horizon-store built output + runtime-read migrations (the migrator reads the
# numbered migrations/*.sql from disk relative to dist/). Sibling layout matters:
# dist/src/horizon-migrator.js resolves ../../migrations.
COPY packages/horizon-store/dist/ ./packages/horizon-store/dist/
COPY packages/horizon-store/migrations/ ./packages/horizon-store/migrations/

# Copy model providers config (if present)
COPY .model_providers.json* ./

# Run as the built-in node user (non-root)
USER node

ENTRYPOINT ["node", "packages/sdk/examples/worker.js"]
