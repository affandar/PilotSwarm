{
  "$schema": "../deploy.schema.json",
  "schemaVersion": 1,
  "_comment": "OSS per-service deploy manifest for worker. Read by deploy/scripts/lib/services-manifest.mjs. Distinct from the EV2 service.json sibling which will be ported to a parent repo.",
  "name": "worker",
  "kind": "app",
  "bicep": {
    "modules": [
      { "name": "base-infra", "scope": "group" },
      { "name": "worker",     "scope": "group" }
    ],
    "allModeModules": [
      { "name": "worker", "scope": "group" }
    ]
  },
  "image": {
    "repo":       "pilotswarm-worker",
    "dockerfile": "deploy/Dockerfile.worker",
    "buildWorkspaces": ["packages/sdk"]
  },
  "rollout": {
    "deployment": "copilot-runtime-worker"
  }
}
