{
    "$schema": "https://ev2schema.azure.net/schemas/2020-01-01/rolloutParameters.json",
    "contentVersion": "1.0.0.0",
    "shellExtensions": [
        {
            "name": "GenerateEnvForEv2",
            "type": "GenerateEnvForEv2",
            "properties": {
                "maxExecutionTime": "PT20M"
            },
            "package": {
                "reference": {
                    "path": "GenerateEnvForEv2.zip"
                }
            },
            "launch": {
                "command": [
                    "/usr/bin/pwsh",
                    "-NoProfile",
                    "-File",
                    "/package/unarchive/GenerateEnvForEv2.ps1",
                    "-OverlayPath",
                    "__DEPLOYMENT_OVERLAY_PATH__"
                ],
                "environmentVariables": [
                    {
                        "name": "IMAGE_TAG",
                        "value": "__IMAGE_TAG__"
                    },
                    {
                        "name": "IMAGE_NAME",
                        "value": "__IMAGE_NAME__"
                    },
                    {
                        "name": "ACR_LOGIN_SERVER",
                        "value": "__ACR_LOGIN_SERVER__"
                    },
                    {
                        "name": "NAMESPACE",
                        "value": "__NAMESPACE__"
                    },
                    {
                        "name": "WORKLOAD_IDENTITY_CLIENT_ID",
                        "value": "__WORKLOAD_IDENTITY_CLIENT_ID__"
                    },
                    {
                        "name": "KV_NAME",
                        "value": "__KV_NAME__"
                    },
                    {
                        "name": "AZURE_TENANT_ID",
                        "value": "__AZURE_TENANT_ID__"
                    },
                    {
                        "name": "AZURE_CLIENT_ID",
                        "value": "__WORKLOAD_IDENTITY_CLIENT_ID__"
                    }
                ],
                "identity": {
                    "type": "systemAssigned"
                }
            }
        }
    ]
}
