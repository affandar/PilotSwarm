{
    "$schema": "https://ev2schema.azure.net/schemas/2020-04-01/RegionAgnosticRolloutSpecification.json",
    "contentVersion": "1.0.0",
    "rolloutMetadata": {
        "serviceModelPath": "serviceModel.json",
        "scopeBindingsPath": "scopeBinding.json",
        "name": "Microsoft.PilotSwarm.Portal",
        "rolloutType": "major",
        "buildSource": {
            "parameters": {
                "versionFile": "version.txt"
            }
        },
        "notification": {
            "email": {
                "to": "pilotswarm-oncall@microsoft.com"
            }
        },
        "configuration": {
            "serviceScope": {
                "specPath": "Configuration\\configurationSettings.json"
            },
            "serviceGroupScope": {
                "specPath": "Configuration\\ServiceGroup\\$serviceGroup().Configuration.json"
            }
        }
    },
    "orchestratedSteps": [
        {
            "name": "PortalServiceInfra",
            "targetType": "ServiceResourceDefinition",
            "targetName": "PortalServiceInfraDefinition",
            "actions": ["deploy"]
        },
        {
            "name": "UploadContainer",
            "targetType": "ServiceResourceDefinition",
            "targetName": "PortalUploadContainerDefinition",
            "actions": ["Shell/UploadContainer"],
            "dependsOn": ["PortalServiceInfra"]
        },
        {
            "name": "GenerateEnvForEv2",
            "targetType": "ServiceResourceDefinition",
            "targetName": "PortalGenerateEnvDefinition",
            "actions": ["Shell/GenerateEnvForEv2"],
            "dependsOn": ["UploadContainer"]
        },
        {
            "name": "DeployApplicationManifest",
            "targetType": "ServiceResourceDefinition",
            "targetName": "PortalDeployApplicationManifestDefinition",
            "actions": ["Shell/DeployApplicationManifest"],
            "dependsOn": ["GenerateEnvForEv2"]
        }
    ]
}
