{
    "$schema": "https://ev2schema.azure.net/schemas/2020-01-01/scopeBindings.json",
    "contentVersion": "1.0.0.0",
    "scopeBindings": [
        {
            "scopeTagName": "globalScope",
            "bindings": [
                {
                    "find": "__REGION_NAME__",
                    "replaceWith": "$config(regionName)"
                },
                {
                    "find": "__REGION_SHORT_NAME__",
                    "replaceWith": "$config(regionShortName)"
                },
                {
                    "find": "__RESOURCE_GROUP_NAME__",
                    "replaceWith": "$azureResourceGroup()"
                },
                {
                    "find": "__RESOURCE_PREFIX__",
                    "replaceWith": "$config(resourcePrefix)"
                },
                {
                    "find": "__RESOURCE_NAME__",
                    "replaceWith": "$config(resourcePrefix)$config(regionShortName)$stamp()"
                },
                {
                    "find": "__STAMP__",
                    "replaceWith": "$stamp()"
                },
                {
                    "find": "__ROLLOUT_TENANTID__",
                    "replaceWith": "$config(TenantId)"
                },
                {
                    "find": "__SSL_CERTIFICATE_DOMAIN_SUFFIX__",
                    "replaceWith": "$config(sslCertificateDomainSuffix)"
                },
                {
                    "find": "__APPROVAL_MANAGED_IDENTITY_ID__",
                    "replaceWith": "$config(approvalManagedIdentityId)"
                },
                {
                    "find": "__APPLICATION_GATEWAY_NAME__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(applicationGatewayName.value)"
                },
                {
                    "find": "__PRIVATE_LINK_CONFIGURATION_NAME__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(privateLinkConfigurationName.value)"
                },
                {
                    "find": "__FRONT_DOOR_PROFILE_NAME__",
                    "replaceWith": "$serviceResourceDefinition(GlobalInfraResourceDefinition).action(deploy).outputs(frontDoorProfileName.value)"
                },
                {
                    "find": "__FRONT_DOOR_PROFILE_RESOURCE_GROUP__",
                    "replaceWith": "$serviceResourceDefinition(GlobalInfraResourceDefinition).action(deploy).outputs(frontDoorProfileResourceGroup.value)"
                },
                {
                    "find": "__FRONT_DOOR_ENDPOINT_NAME__",
                    "replaceWith": "$serviceResourceDefinition(GlobalInfraResourceDefinition).action(deploy).outputs(frontDoorEndpointName.value)"
                },
                {
                    "find": "__IMAGE_NAME__",
                    "replaceWith": "$config(portalImageName)"
                },
                {
                    "find": "__IMAGE_TAG__",
                    "replaceWith": "$buildVersion()"
                },
                {
                    "find": "__BUILD_VERSION__",
                    "replaceWith": "$buildVersion()"
                },
                {
                    "find": "__APP_IMAGE_FILE_PATH__",
                    "replaceWith": "ContainerImages/$config(portalImageName).tar.gz"
                },
                {
                    "find": "__NAMESPACE__",
                    "replaceWith": "$config(portalNamespace)"
                },
                {
                    "find": "__DEPLOYMENT_STORAGE_CONTAINER_NAME__",
                    "replaceWith": "portal-manifests"
                },
                {
                    "find": "__DEPLOYMENT_OVERLAY_PATH__",
                    "replaceWith": "$config(portalOverlayPath)"
                },
                {
                    "find": "__APPLICATION_MANIFEST_PARAMETERS_FILE__",
                    "replaceWith": "Parameters/DeployApplicationManifest.parameters.json"
                }
            ]
        },
        {
            "scopeTagName": "aksAppDeployScope",
            "bindings": [
                {
                    "find": "__ACR_LOGIN_SERVER__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(acrLoginServer.value)"
                },
                {
                    "find": "__ACR_NAME__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(acrName.value)"
                },
                {
                    "find": "__KV_NAME__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(keyVaultName.value)"
                },
                {
                    "find": "__BLOB_CONTAINER_ENDPOINT__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(blobContainerEndpoint.value)"
                },
                {
                    "find": "__AKS_CLUSTER_NAME__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(aksClusterName.value)"
                },
                {
                    "find": "__WORKLOAD_IDENTITY_CLIENT_ID__",
                    "replaceWith": "$config(portalWorkloadIdentityClientId)"
                },
                {
                    "find": "__AZURE_TENANT_ID__",
                    "replaceWith": "$config(TenantId)"
                },
                {
                    "find": "__DEPLOYMENT_STORAGE_ACCOUNT_NAME__",
                    "replaceWith": "$config(resourcePrefix)$config(regionShortName)$stamp()sa"
                },
                {
                    "find": "__PORTAL_HOSTNAME__",
                    "replaceWith": "$serviceResourceDefinition(PortalServiceInfraDefinition).action(deploy).outputs(BackendHostName.value)"
                },
                {
                    "find": "__ACI_SUBNET_ID__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(aciSubnetId.value)"
                },
                {
                    "find": "__SERVICE_DEPLOY_MANAGED_IDENTITY_RESOURCE_ID__",
                    "replaceWith": "$serviceResourceDefinition(BaseInfraDefinition).action(deploy).outputs(ev2DeployIdentityResourceId.value)"
                }
            ]
        }
    ]
}
