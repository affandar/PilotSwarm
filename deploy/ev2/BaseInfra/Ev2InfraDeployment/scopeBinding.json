{
    "$schema": "https://ev2schema.azure.net/schemas/2020-01-01/scopeBindings.json",
    "contentVersion": "1.0.0.0",
    "scopeBindings": [
        {
            "scopeTagName": "globalScope",
            "bindings": [
                {
                    "find": "__REGION_NAME__",
                    "replaceWith": "$config(regionName)"
                },
                {
                    "find": "__REGION_SHORT_NAME__",
                    "replaceWith": "$config(regionShortName)"
                },
                {
                    "find": "__RESOURCE_GROUP_NAME__",
                    "replaceWith": "$azureResourceGroup()"
                },
                {
                    "find": "__RESOURCE_PREFIX__",
                    "replaceWith": "$config(resourcePrefix)"
                },
                {
                    "find": "__RESOURCE_NAME_PREFIX__",
                    "replaceWith": "$config(resourcePrefix)$config(regionShortName)$stamp()"
                },
                {
                    "find": "__STAMP__",
                    "replaceWith": "$stamp()"
                },
                {
                    "find": "__ROLLOUT_TENANTID__",
                    "replaceWith": "$config(TenantId)"
                },
                {
                    "find": "__FRONT_DOOR_PROFILE_NAME__",
                    "replaceWith": "$serviceResourceDefinition(GlobalInfraResourceDefinition).action(deploy).outputs(frontDoorProfileName.value)"
                },
                {
                    "find": "__FRONT_DOOR_PROFILE_RESOURCE_GROUP__",
                    "replaceWith": "$serviceResourceDefinition(GlobalInfraResourceDefinition).action(deploy).outputs(frontDoorProfileResourceGroup.value)"
                },
                {
                    "find": "__SSL_CERTIFICATE_DOMAIN_SUFFIX__",
                    "replaceWith": "$config(sslCertificateDomainSuffix)"
                },
                {
                    "find": "__WAF_MODE__",
                    "replaceWith": "$config(wafMode)"
                },
                {
                    "find": "__ACR_SKU__",
                    "replaceWith": "$config(acrSku)"
                },
                {
                    "find": "__APP_GATEWAY_PRIVATE_IP__",
                    "replaceWith": "$config(appGatewayPrivateIpAddress)"
                },
                {
                    "find": "\"__AVAILABILITY_ZONES__\"",
                    "replaceWith": "$config(availabilityZones)"
                },
                {
                    "find": "__ENVIRONMENT_LOWER__",
                    "replaceWith": "$config(environmentLower)"
                }
            ]
        }
    ]
}
