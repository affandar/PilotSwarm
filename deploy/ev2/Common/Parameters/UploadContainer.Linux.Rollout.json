{
    "$schema": "https://ev2schema.azure.net/schemas/2020-01-01/rolloutParameters.json",
    "contentVersion": "1.0.0.0",
    "shellExtensions": [
        {
            "name": "UploadContainer",
            "type": "UploadContainer",
            "properties": {
                "maxExecutionTime": "PT50M"
            },
            "package": {
                "reference": {
                    "path": "UploadContainer.zip"
                }
            },
            "launch": {
                "command": [
                    "/bin/bash",
                    "/package/unarchive/UploadContainer.sh"
                ],
                "environmentVariables": [
                    {
                        "name": "DEPLOYMENT_ACR_NAME",
                        "value": "__ACR_NAME__"
                    },
                    {
                        "name": "TARBALL_IMAGE_FILE_SAS",
                        "reference": {
                            "path": "__APP_IMAGE_FILE_PATH__"
                        },
                        "asSecureValue": "true"
                    },
                    {
                        "name": "DESTINATION_FILE_NAME",
                        "value": "__IMAGE_NAME__.tar.gz"
                    },
                    {
                        "name": "IMAGE_NAME",
                        "value": "__IMAGE_NAME__"
                    },
                    {
                        "name": "TAG_NAME",
                        "value": "__BUILD_VERSION__"
                    }
                ],
                "identity": {
                    "type": "userAssigned",
                    "userAssignedIdentities": [
                        "__SERVICE_DEPLOY_MANAGED_IDENTITY_RESOURCE_ID__"
                    ]
                },
                "subnetIds": [
                    {
                        "id": "__ACI_SUBNET_ID__"
                    }
                ]
            }
        }
    ]
}
