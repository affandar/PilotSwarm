{
    "$schema": "https://ev2schema.azure.net/schemas/2020-01-01/rolloutParameters.json",
    "contentVersion": "1.0.0.0",
    "shellExtensions": [
        {
            "name": "DeployApplicationManifest",
            "type": "DeployApplicationManifest",
            "properties": {
                "maxExecutionTime": "PT50M"
            },
            "package": {
                "reference": {
                    "path": "DeployApplicationManifest.zip"
                }
            },
            "launch": {
                "command": [
                    "/bin/bash",
                    "/package/unarchive/DeployApplicationManifest.sh"
                ],
                "environmentVariables": [
                    {
                        "name": "DEPLOYMENT_STORAGE_ACCOUNT_NAME",
                        "value": "__DEPLOYMENT_STORAGE_ACCOUNT_NAME__"
                    },
                    {
                        "name": "DEPLOYMENT_STORAGE_CONTAINER_NAME",
                        "value": "__DEPLOYMENT_STORAGE_CONTAINER_NAME__"
                    },
                    {
                        "name": "DEPLOYMENT_OVERLAY_PATH",
                        "value": "__DEPLOYMENT_OVERLAY_PATH__"
                    },
                    {
                        "name": "APPLICATION_MANIFESTS_SAS",
                        "reference": {
                            "path": "manifests.zip"
                        },
                        "asSecureValue": "true"
                    },
                    {
                        "name": "DESTINATION_FILE_NAME",
                        "value": "manifests.zip"
                    },
                    {
                        "name": "APPLICATION_MANIFEST_PARAMETERS_SAS",
                        "reference": {
                            "path": "__APPLICATION_MANIFEST_PARAMETERS_FILE__",
                            "enableScopeTagBindings": "true"
                        },
                        "asSecureValue": "true"
                    }
                ],
                "identity": {
                    "type": "userAssigned",
                    "userAssignedIdentities": [
                        "__SERVICE_DEPLOY_MANAGED_IDENTITY_RESOURCE_ID__"
                    ]
                },
                "subnetIds": [
                    {
                        "id": "__ACI_SUBNET_ID__"
                    }
                ]
            }
        }
    ]
}
