# Optional HorizonDB provider overlay for PilotSwarm tests and local runs.
#
# Copy this file to `.env.horizondb` (gitignored) and fill in real values.
# `./scripts/run-tests.sh` does NOT load this overlay by default. Use:
#   ./scripts/run-tests.sh --with-horizondb
# or:
#   ./scripts/run-tests.sh --all-providers
#
# The shipped worker entrypoints map these env vars through horizonConfigFromEnv():
#   HORIZON_DATABASE_URL       -> worker.enhancedFactsDatabaseUrl
#   HORIZON_FACTS_SCHEMA       -> worker.enhancedFactsSchema
#   HORIZON_GRAPH_DATABASE_URL -> worker.graphDatabaseUrl
#   HORIZON_GRAPH_SCHEMA       -> worker.graphSchema
#   HORIZON_EMBED_*            -> worker.horizonEmbed

# Enhanced facts store target (pgvector / pg_textsearch / pg_durable).
# Setting this enables the HorizonDB EnhancedFactStore provider.
# HorizonDB TLS: `?sslmode=require` is enough for the provider; raw psql/pg
# clients that bypass the provider may also need `uselibpqcompat=true`.
HORIZON_DATABASE_URL=postgresql://user:pass@<cluster>.postgres.database.azure.com:5432/postgres?sslmode=require
HORIZON_FACTS_SCHEMA=horizon_facts

# Optional SEPARATE knowledge-graph target (Apache AGE). Unset means no graph
# store and no graph tools. This may reuse HORIZON_DATABASE_URL, but the graph
# schema/name must differ from HORIZON_FACTS_SCHEMA because AGE creates a PG
# schema named after the graph.
HORIZON_GRAPH_DATABASE_URL=postgresql://user:pass@<cluster>.postgres.database.azure.com:5432/postgres?sslmode=require
HORIZON_GRAPH_SCHEMA=horizon_graph

# Optional embedding endpoint for the in-DB durable embedder. Omit these to run
# enhanced search in lexical-only mode; semantic search needs embedded rows.
# HORIZON_EMBED_URL is the full embeddings POST URL (deployment in path + api-version).
HORIZON_EMBED_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>/embeddings?api-version=2024-02-01
HORIZON_EMBED_MODEL=text-embedding-3-small
HORIZON_EMBED_DIM=1536
HORIZON_EMBED_API_KEY=<embed-key>
HORIZON_EMBED_API_KEY_HEADER=api-key
# HORIZON_EMBED_BEARER=false
