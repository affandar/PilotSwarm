# Connection to a HorizonDB instance (preview) with pg_textsearch, AI pipelines,
# AGE, and pg_durable enabled. PoCs read this; nothing here touches a PilotSwarm DB.
HORIZON_DATABASE_URL=postgresql://user:pass@localhost:5432/horizon_facts_poc

# Embedding model wiring used by the AI-pipeline PoC. Placeholder values only.
HZ_EMBED_MODEL=text-embedding-3-small
HZ_EMBED_DIM=1536
